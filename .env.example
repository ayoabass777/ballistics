# Database
DB_NAME=ballistics
DB_USER=ballistics_user
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# Football API (api-football via RapidAPI)
API_KEY=your_api_key_here
API_HOST=api-football-v1.p.rapidapi.com
API_URL=https://v3.football.api-sports.io/

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=ca-central-1
S3_BUCKET=ballistics-raw

# Airflow
AIRFLOW__WEBSERVER__SECRET_KEY=change-this-to-a-random-string
AIRFLOW__WEBSERVER__DEFAULT_USER_PASSWORD=admin

# Season tracker (earliest season to process)
MIN_SEASON_TRACKER=2020
